# Capisco dev config — copy to `app/.env.local` (gitignored, never committed) and fill in.
# Values are read by the dev sidecar at startup, vaulted in the broker, and
# injected ONLY at the execution layer — never passed to the agent subprocess
# env/argv and never sent to the browser/LLM context.
#
# Later (production), these move to the global Capisco config (~/.config/capisco/)
# / OS keychain; the dev `.env.local` path is for local development only.

# --- Real ACP agent (option 1) — leave unset to use the deterministic stub ---
# An ACP-capable agent CLI must be INSTALLED on your machine for this path.
# CAPISCO_ACP_CLI=claude-code        # or: codex / gemini — must be on PATH
# CAPISCO_ACP_CLI_ARGS=              # optional extra args
# CAPISCO_ACP_MODEL=                 # optional model id
# CAPISCO_ACP_API_KEY=               # the CLI's API key (vaulted on startup); or:
# CAPISCO_ACP_CRED_REF=anthropic     # reference a key already in the vault

# --- Dev bridge (optional overrides) ---
# CAPISCO_DEV_BRIDGE_PORT=
# CAPISCO_DEV_REPO=/absolute/path/to/a/repo   # auto-open a repo on boot
# VITE_CAPISCO_DEV_BRIDGE=off        # force the mock fallback (no real sidecar)
