{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "agent.jsx",
              "chrome.jsx",
              "components/core/**",
              "components/ide/**",
              "components/indicators/**",
              "panels.jsx",
              "ui_kits/capisco-ide/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|ghost)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EditorTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|pinned|dirty|onSelect|onClose|style|key|ref|className|style|children)$/]",
        "message": "<EditorTab> doesn't accept that prop. Declared props: icon, label, active, pinned, dirty, onSelect, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GitMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|style|key|ref|className|style|children)$/]",
        "message": "<GitMarker> doesn't accept that prop. Declared props: status, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GitMarker'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:M|A|D|U)$/]",
        "message": "<GitMarker> status must be one of 'M' | 'A' | 'D' | 'U'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|active|edge|size|title|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, active, edge, size, title, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='edge'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<IconButton> edge must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:leading|trailing|mono|disabled|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: leading, trailing, mono, disabled, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<ModelBadge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent)$/]",
        "message": "<ModelBadge> tone must be one of 'neutral' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PermissionPrompt'] > JSXAttribute > JSXIdentifier[name!=/^(?:command|label|scopes|onGrant|style|key|ref|className|style|children)$/]",
        "message": "<PermissionPrompt> doesn't accept that prop. Declared props: command, label, scopes, onGrant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:running|idle|waiting|error|done)$/]",
        "message": "<StatusDot> status must be one of 'running' | 'idle' | 'waiting' | 'error' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|target|added|removed|expanded|onToggle|onOpen|children|style|key|ref|className|style|children)$/]",
        "message": "<ToolAction> doesn't accept that prop. Declared props: kind, target, added, removed, expanded, onToggle, onOpen, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TreeRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:depth|expandable|expanded|icon|label|active|muted|trailing|onClick|style|key|ref|className|style|children)$/]",
        "message": "<TreeRow> doesn't accept that prop. Declared props: depth, expandable, expanded, icon, label, active, muted, trailing, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
